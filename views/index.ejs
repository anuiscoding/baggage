<%- include('./partials/header') %>

<% if(error && error.length>0){ %> <div class="absolute top-6 left-1/2 -translate-x-1/2 z-50 px-5 py-3 rounded-xl bg-red-500/90 shadow-lg backdrop-blur-md"> <span class="text-white font-medium">
<%= error %> </span> </div>
<% } %>

<div class="w-full h-screen flex bg-gradient-to-br from-[#0f172a] via-[#1e293b] to-[#020617] text-white">

<!-- LEFT: REGISTER -->
<div class="w-[48%] flex items-center justify-center h-screen">
    <div class="w-full px-24">
        <h3 class="text-4xl font-semibold tracking-tight mb-2">
            Welcome to <span class="text-indigo-400">Baggage</span>
        </h3>
        <p class="text-slate-400 mb-6">Create your account and start your journey</p>

        <form
            class="flex flex-col items-center justify-center mt-3 bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl shadow-2xl p-6 transition-all duration-300 hover:shadow-indigo-500/10"
            autocomplete="off" action="/users/register" method="post">

            <h4 class="text-xl mb-4 text-slate-200">Create Account</h4>

            <input
                class="bg-white/10 text-white placeholder-slate-400 outline-none w-[80%] px-4 py-2 rounded-xl mb-3 border border-white/10 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-400/40 transition"
                type="text" placeholder="Full Name" name="fullname">

            <input
                class="bg-white/10 text-white placeholder-slate-400 outline-none w-[80%] px-4 py-2 rounded-xl mb-3 border border-white/10 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-400/40 transition"
                type="email" placeholder="Email" name="email">

            <input
                class="bg-white/10 text-white placeholder-slate-400 outline-none w-[80%] px-4 py-2 rounded-xl mb-4 border border-white/10 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-400/40 transition"
                type="password" placeholder="Password" name="password">

            <input 
                type="submit"
                value="Create Account"
                class="w-1/3 rounded-3xl bg-gradient-to-r from-indigo-500 to-purple-500 text-white font-semibold py-2.5 transition-all duration-300 hover:scale-[1.02] hover:shadow-lg hover:shadow-indigo-500/30 active:scale-95 cursor-pointer"
            />
        </form>
    </div>
</div>

<!-- CENTER -->
<div class="flex items-center justify-center text-slate-500 text-lg font-medium">
    OR
</div>

<!-- RIGHT: LOGIN -->
<div class="w-[48%] flex items-center justify-center h-screen">
    <div class="w-full px-24">

        <form
            class="mt-24 flex flex-col items-center justify-center bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl shadow-2xl p-6 transition-all duration-300 hover:shadow-purple-500/10"
            autocomplete="off" action="/users/login" method="post">

            <h4 class="text-2xl mb-4 text-slate-200">Login</h4>

            <input
                class="bg-white/10 text-white placeholder-slate-400 outline-none w-[80%] px-4 py-2 rounded-xl mb-3 border border-white/10 focus:border-purple-400 focus:ring-2 focus:ring-purple-400/40 transition"
                type="email" placeholder="Email" name="email">

            <input
                class="bg-white/10 text-white placeholder-slate-400 outline-none w-[80%] px-4 py-2 rounded-xl mb-4 border border-white/10 focus:border-purple-400 focus:ring-2 focus:ring-purple-400/40 transition"
                type="password" placeholder="Password" name="password">

            <input
                type="submit"
                value="Login"
                class="w-1/4 rounded-3xl bg-gradient-to-r from-purple-500 to-pink-500 text-white font-semibold py-2.5 transition-all duration-300 hover:scale-[1.02] hover:shadow-lg hover:shadow-purple-500/30 active:scale-95 cursor-pointer"
            />
        </form>
    </div>
</div>
```

</div>

<%- include('./partials/footer') %>
